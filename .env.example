# Postgres database for Prisma and Auth.js session/user data.
DATABASE_URL="postgresql://db_user:db_password@db-host.example.com:5432/liveoak_npsot?schema=public"

# Long random secret used by Auth.js for signing and encryption.
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Verified sender in the exact format: Display Name <email@example.com>
AUTH_EMAIL_FROM="Live Oak Chapter <members@liveoak-npsot.org>"

# Resend API key for magic-link email delivery.
AUTH_RESEND_API_KEY="re_replace_with_resend_api_key"

# Full base URL for this environment. Use http://localhost:3000 locally and the exact deployed https URL in staging/production.
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob read/write token for member post image uploads.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_replace_with_real_token"
