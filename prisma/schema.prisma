generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  admin
  member
}

enum ExchangeCategory {
  seeds
  plants
  trees
  tools
  giveaway
  help_requested
  help_offered
}

enum ExchangePostStatus {
  open
  pending
  completed
  closed
}

enum ExchangeImageVisibility {
  member_only
  public_teaser
}

enum PointLedgerReason {
  completed_interaction
}

model User {
  id                      String                @id @default(cuid())
  name                    String?
  email                   String?               @unique
  emailVerified           DateTime?
  image                   String?
  role                    MemberRole            @default(member)
  pointsTotal             Int                   @default(0)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  accounts                Account[]
  sessions                Session[]
  exchangePosts           ExchangePost[]        @relation("ExchangePostAuthor")
  exchangeReplies         ExchangeReply[]
  counterpartTransactions ExchangeTransaction[] @relation("TransactionCounterpart")
  pointLedgerEntries      PointLedger[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ExchangePost {
  id                String             @id @default(cuid())
  title             String
  description       String             @db.Text
  category          ExchangeCategory
  county            String?
  availabilityNotes String?            @db.Text
  swapPreference    String?            @db.Text
  status            ExchangePostStatus @default(open)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  authorId          String
  author            User               @relation("ExchangePostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  images            ExchangePostImage[]
  replies           ExchangeReply[]
  transaction       ExchangeTransaction?

  @@index([category, status, createdAt])
  @@index([authorId, createdAt])
}

model ExchangePostImage {
  id         String                  @id @default(cuid())
  postId     String
  post       ExchangePost            @relation(fields: [postId], references: [id], onDelete: Cascade)
  blobUrl    String
  blobPath   String
  visibility ExchangeImageVisibility @default(member_only)
  sortOrder  Int                     @default(0)
  createdAt  DateTime                @default(now())

  @@index([postId, sortOrder])
}

model ExchangeReply {
  id        String       @id @default(cuid())
  postId    String
  authorId  String
  body      String       @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  post      ExchangePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model ExchangeTransaction {
  id                    String        @id @default(cuid())
  postId                String        @unique
  counterpartId         String?
  ownerConfirmedAt      DateTime?
  counterpartConfirmedAt DateTime?
  completedAt           DateTime?
  pointsAwardedAt       DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  post                  ExchangePost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  counterpart           User?         @relation("TransactionCounterpart", fields: [counterpartId], references: [id], onDelete: SetNull)
  ledgerEntries         PointLedger[]
}

model PointLedger {
  id            String            @id @default(cuid())
  userId        String
  transactionId String
  reason        PointLedgerReason
  points        Int               @default(1)
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction   ExchangeTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([userId, transactionId, reason])
  @@index([userId, createdAt])
}
